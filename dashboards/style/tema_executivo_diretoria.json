{
  "name": "Tema Executivo Diretoria",
  "dataColors": [
    "#1F6FEB",
    "#3FB950",
    "#D29922",
    "#F85149",
    "#58A6FF",
    "#79C0FF",
    "#56D364",
    "#E3B341"
  ],
  "background": "#0D1117",
  "foreground": "#E6EDF3",
  "tableAccent": "#1F6FEB",
  "visualStyles": {
    "*": {
      "*": {
        "background": [{ "color": { "solid": { "color": "#161B22" } } }],
        "title": [{
          "show": true,
          "fontColor": { "solid": { "color": "#8B949E" } },
          "fontSize": 10,
          "fontFamily": "Segoe UI",
          "bold": false,
          "alignment": "left",
          "background": { "solid": { "color": "#161B22" } }
        }]
      }
    },
    "card": {
      "*": {
        "calloutValue": [{
          "fontSize": 28,
          "fontFamily": "Segoe UI Semibold",
          "fontColor": { "solid": { "color": "#E6EDF3" } }
        }],
        "categoryLabel": [{
          "show": true,
          "fontSize": 10,
          "fontFamily": "Segoe UI",
          "fontColor": { "solid": { "color": "#8B949E" } }
        }],
        "background": [{ "color": { "solid": { "color": "#161B22" } }, "transparency": 0 }]
      }
    },
    "lineChart": {
      "*": {
        "valueAxis": [{
          "gridlineColor": { "solid": { "color": "#21262D" } },
          "fontColor": { "solid": { "color": "#8B949E" } },
          "fontSize": 10
        }],
        "categoryAxis": [{
          "fontColor": { "solid": { "color": "#8B949E" } },
          "fontSize": 10
        }],
        "legend": [{ "fontColor": { "solid": { "color": "#8B949E" } }, "fontSize": 11 }]
      }
    },
    "barChart": {
      "*": {
        "valueAxis": [{
          "gridlineColor": { "solid": { "color": "#21262D" } },
          "fontColor": { "solid": { "color": "#8B949E" } },
          "fontSize": 10
        }],
        "categoryAxis": [{
          "fontColor": { "solid": { "color": "#C9D1D9" } },
          "fontSize": 11
        }],
        "legend": [{ "fontColor": { "solid": { "color": "#8B949E" } }, "fontSize": 11 }]
      }
    },
    "clusteredBarChart": {
      "*": {
        "valueAxis": [{
          "gridlineColor": { "solid": { "color": "#21262D" } },
          "fontColor": { "solid": { "color": "#8B949E" } },
          "fontSize": 10
        }],
        "categoryAxis": [{
          "fontColor": { "solid": { "color": "#C9D1D9" } },
          "fontSize": 11
        }]
      }
    },
    "donutChart": {
      "*": {
        "legend": [{ "fontColor": { "solid": { "color": "#8B949E" } }, "fontSize": 11 }]
      }
    },
    "pieChart": {
      "*": {
        "legend": [{ "fontColor": { "solid": { "color": "#8B949E" } }, "fontSize": 11 }]
      }
    },
    "tableEx": {
      "*": {
        "header": [{
          "fontColor": { "solid": { "color": "#8B949E" } },
          "fontSize": 11,
          "background": { "solid": { "color": "#21262D" } }
        }],
        "values": [{
          "fontColorPrimary": { "solid": { "color": "#E6EDF3" } },
          "fontColorSecondary": { "solid": { "color": "#C9D1D9" } },
          "backgroundPrimary": { "solid": { "color": "#161B22" } },
          "backgroundSecondary": { "solid": { "color": "#0D1117" } },
          "fontSize": 11
        }]
      }
    },
    "slicer": {
      "*": {
        "data": [{ "fontColor": { "solid": { "color": "#E6EDF3" } }, "fontSize": 12 }],
        "header": [{ "fontColor": { "solid": { "color": "#8B949E" } }, "fontSize": 11 }]
      }
    }
  }
}
